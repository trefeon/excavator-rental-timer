# Ignore everything in the root
/*

# Whitelist directories and root files
!/firmware/
!/docs/
!.gitignore
!/platformio.ini
!/README.md

# ----------------------------------------------------
# Blacklist specific patterns inside the whitelisted dirs
# ----------------------------------------------------

# OS & IDE
**/.DS_Store
**/Thumbs.db
**/desktop.ini
**/.vscode/
**/.idea/
**/*.swp
**/*.swo
**/*~

# PlatformIO & Build artifacts
**/.pio/
**/.pioenvs/
**/.piolibdeps/
**/build/
**/*.o
**/*.elf
**/*.bin
**/*.hex
**/*.map

# Docs specific ignores
/docs/*.pdf
!/docs/ANDROID_APP_GUIDE.pdf
/docs/convert.ps1
